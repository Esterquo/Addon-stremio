# Variáveis de Ambiente - Exemplo
# Copie para .env e configure seus valores

# Porta do servidor (Render define automaticamente)
PORT=10000

# Nuvio API Configuration
NUVIO_API_KEY=sua_chave_api_aqui
NUVIO_API_URL=https://api.nuvio.com

# Intervalo de atualização do catálogo (em milissegundos)
# Padrão: 3600000 (1 hora)
UPDATE_INTERVAL=3600000
